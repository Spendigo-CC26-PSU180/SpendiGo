---
import SidebarSummary from './SidebarSummary';

const currentPath = Astro.url.pathname;

const menuItems = [
  { href: '/dashboard', label: 'Dashboard', icon: 'home' },
  { href: '/transactions', label: 'Transaksi', icon: 'wallet' },
  { href: '/settings', label: 'Pengaturan', icon: 'settings' },
];

const aiItems = [
  { href: '/insights', label: 'Insights', icon: 'sparkles' },
  { href: '/chat', label: 'Chat Spen', icon: 'chat' },
];

const isActive = (href: string) => currentPath === href || currentPath.startsWith(href + '/');
---

<aside class="hidden lg:flex flex-col w-64 bg-white border-r border-gray-100 h-screen sticky top-0 relative overflow-hidden">
  <!-- Spen Background Decoration -->
  <div class="absolute bottom-0 right-0 w-40 h-40 opacity-[0.06] pointer-events-none">
    <img src="/spen.png" alt="" class="w-full h-full object-contain" />
  </div>

  <!-- Logo -->
  <div class="p-4">
    <a href="/dashboard" class="block">
      <img src="/logo.png" alt="SpendiGo" class="h-10 w-auto" />
    </a>
  </div>

  <!-- Mini Financial Summary -->
  <div class="px-4">
    <SidebarSummary client:load />
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-4">
    <!-- MENU Section -->
    <div class="mb-4">
      <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2 px-2">Menu</p>
      <ul class="space-y-1">
        {menuItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 ${
                isActive(item.href)
                  ? 'bg-primary-50 text-primary-600 font-medium border-l-4 border-primary-500 -ml-[4px] pl-[calc(0.75rem+4px)]'
                  : 'text-gray-600 hover:bg-gray-50'
              }`}
            >
              {item.icon === 'home' && (
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
              )}
              {item.icon === 'wallet' && (
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
              )}
              {item.icon === 'settings' && (
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              )}
              <span>{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- AI FEATURES Section -->
    <div>
      <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2 px-2">AI Features</p>
      <ul class="space-y-1">
        {aiItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 ${
                isActive(item.href)
                  ? 'bg-primary-50 text-primary-600 font-medium border-l-4 border-primary-500 -ml-[4px] pl-[calc(0.75rem+4px)]'
                  : 'text-gray-600 hover:bg-gray-50'
              }`}
            >
              {item.icon === 'sparkles' && (
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
              )}
              {item.icon === 'chat' && (
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
              )}
              <span>{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- User Info & Logout -->
  <div class="p-4 border-t border-gray-100 relative z-10">
    <div id="user-info" class="flex items-center gap-3 p-3 rounded-xl bg-gray-50">
      <div class="w-10 h-10 bg-gradient-to-br from-primary-400 to-accent-400 rounded-full flex items-center justify-center">
        <span id="user-avatar" class="text-white font-semibold">?</span>
      </div>
      <div class="flex-1 min-w-0">
        <p id="user-name" class="text-sm font-medium text-gray-900 truncate">Loading...</p>
        <p id="user-email" class="text-xs text-gray-500 truncate">...</p>
      </div>
    </div>
    <button
      id="logout-btn"
      class="w-full mt-3 flex items-center justify-center gap-2 px-4 py-2 text-sm text-gray-600 hover:text-red-600 hover:bg-red-50 rounded-xl transition-all"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
      </svg>
      Logout
    </button>
  </div>
</aside>

<script>
  import { auth } from '../../lib/auth';

  document.addEventListener('DOMContentLoaded', () => {
    const user = auth.getUser();
    if (user) {
      const avatarEl = document.getElementById('user-avatar');
      const nameEl = document.getElementById('user-name');
      const emailEl = document.getElementById('user-email');

      if (avatarEl) avatarEl.textContent = user.username.charAt(0).toUpperCase();
      if (nameEl) nameEl.textContent = user.full_name || user.username;
      if (emailEl) emailEl.textContent = user.email;
    }

    const logoutBtn = document.getElementById('logout-btn');
    logoutBtn?.addEventListener('click', () => {
      auth.logout();
    });
  });
</script>
