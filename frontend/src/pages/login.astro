---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Login ke Spendigo" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Login | Spendigo</title>
  </head>
  <body class="min-h-screen bg-gradient-to-br from-primary-50 via-white to-accent-50">
    <div class="min-h-screen flex items-center justify-center p-4">
      <div class="w-full max-w-md">
        <!-- Logo -->
        <div class="text-center mb-8">
          <img src="/logo.png" alt="SpendiGo" class="h-16 mx-auto mb-2" />
        </div>

        <!-- Form Card -->
        <div class="bg-white rounded-2xl shadow-xl p-8">
          <h2 class="text-xl font-semibold text-gray-900 mb-6">Masuk ke akun</h2>

          <form id="login-form" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="input"
                placeholder="email@example.com"
              />
            </div>

            <div>
              <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
              <input
                type="password"
                id="password"
                name="password"
                required
                minlength="8"
                class="input"
                placeholder="Min. 8 karakter"
              />
            </div>

            <div id="error-message" class="hidden p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-600"></div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full btn btn-primary py-3"
            >
              <span id="btn-text">Masuk</span>
              <svg id="btn-loading" class="hidden animate-spin h-5 w-5" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </button>
          </form>

          <p class="text-center text-sm text-gray-500 mt-6">
            Belum punya akun?
            <a href="/register" class="text-primary-500 font-medium hover:text-primary-600">Daftar sekarang</a>
          </p>
        </div>
      </div>
    </div>

    <script>
      import { authApi } from '../lib/api';
      import { auth } from '../lib/auth';

      // Check if already logged in
      if (auth.isAuthenticated()) {
        window.location.href = '/dashboard';
      }

      const form = document.getElementById('login-form') as HTMLFormElement;
      const errorDiv = document.getElementById('error-message') as HTMLDivElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const btnText = document.getElementById('btn-text') as HTMLSpanElement;
      const btnLoading = document.getElementById('btn-loading') as SVGElement;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;

        // Show loading
        submitBtn.disabled = true;
        btnText.textContent = 'Masuk...';
        btnLoading.classList.remove('hidden');
        errorDiv.classList.add('hidden');

        try {
          const response = await authApi.login({ email, password });
          const { user, access_token } = response.data;

          auth.login(access_token, user);
          window.location.href = '/dashboard';
        } catch (error: any) {
          const message = error.response?.data?.detail || 'Terjadi kesalahan, coba lagi';
          errorDiv.textContent = message;
          errorDiv.classList.remove('hidden');

          submitBtn.disabled = false;
          btnText.textContent = 'Masuk';
          btnLoading.classList.add('hidden');
        }
      });
    </script>
  </body>
</html>
