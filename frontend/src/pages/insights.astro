---
import Layout from '../components/layout/Layout.astro';
import PredictionCard from '../components/insights/PredictionCard';
import InsightCards from '../components/insights/InsightCards';
import HealthScore from '../components/insights/HealthScore';
import CategoryComparison from '../components/insights/CategoryComparison';
---

<Layout title="Insights">
  <div class="p-4 lg:p-8">
    <!-- Header with Spen -->
    <div class="mb-4 sm:mb-6 flex items-center gap-3 sm:gap-4">
      <img src="/spen.png" alt="Spen AI" class="w-12 h-12 sm:w-16 sm:h-16" />
      <div>
        <h1 class="text-lg sm:text-2xl font-bold text-gray-900">Halo, aku Spen!</h1>
        <p class="text-xs sm:text-base text-gray-500">AI assistant yang bantu analisis keuanganmu</p>
      </div>
    </div>

    <!-- Main Grid -->
    <div class="grid lg:grid-cols-2 gap-4 sm:gap-6 mb-4 sm:mb-6">
      <!-- Prediction Card - Hero -->
      <PredictionCard client:load />

      <!-- Health Score -->
      <HealthScore client:load />
    </div>

    <!-- Insights Cards -->
    <div class="mb-6">
      <InsightCards client:load />
    </div>

    <!-- Category Comparison -->
    <CategoryComparison client:load />
  </div>
</Layout>
